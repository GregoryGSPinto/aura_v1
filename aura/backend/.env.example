AURA_APP_NAME=Aura
AURA_ENV=development
AURA_VERSION=1.0.0
AURA_API_PREFIX=/api/v1
AURA_LOCAL_MODE=true
AURA_AUTH_MODE=local
AURA_MODEL=qwen3.5:9b
OLLAMA_URL=http://localhost:11434
AURA_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://aura-assistent.vercel.app
AURA_AUTH_TOKEN=change-me
AURA_REQUIRE_AUTH=true
AURA_ENABLE_JOBS=true
AURA_ENABLE_ROUTINES=false
AURA_ENABLE_VOICE=true
AURA_ENABLE_OS_RUNTIME=false
AURA_ENABLE_RESEARCH=false
AURA_ENABLE_CLOUD_PROVIDERS=false
AURA_PROJECTS_FILE=./data/json/projects.json
AURA_SETTINGS_FILE=./data/json/settings.json
AURA_AUDIT_LOG_FILE=./data/logs/audit.log
AURA_AUDIT_JSON_FILE=./data/json/audit_logs.json
AURA_CHAT_SESSIONS_FILE=./data/json/chat_sessions.json
AURA_CHAT_MESSAGES_FILE=./data/json/chat_messages.json
AURA_COMPANION_MEMORY_FILE=./data/json/companion_memory.json
AURA_JOBS_FILE=./data/json/jobs.json
AURA_JOB_LOGS_FILE=./data/json/job_logs.json
AURA_ROUTINES_FILE=./data/json/routines.json
AURA_ROUTINE_EXECUTIONS_FILE=./data/json/routine_executions.json
AURA_COMMAND_TIMEOUT=30
AURA_LLM_TIMEOUT=120
AURA_HTTP_TIMEOUT=20
AURA_JOB_POLL_INTERVAL=2
AURA_DEFAULT_PROJECTS_ROOT=/Users/user_pc/Projetos
# Login da interface
AURA_ADMIN_USERNAME=admin
AURA_ADMIN_PASSWORD=change-me

AURA_SUPABASE_ENABLED=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# === AI Providers ===
# Ollama roda local, não precisa de key
# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_DAILY_BUDGET_CENTS=200
# OpenAI (GPT) — https://platform.openai.com/
OPENAI_API_KEY=

# === Token Budget ===
# Limites diário e mensal em USD para providers pagos
TOKEN_BUDGET_DAILY_USD=5.0
TOKEN_BUDGET_MONTHLY_USD=100.0

# === Integrações Externas ===
# GitHub — https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_USERNAME=

# Vercel — https://vercel.com/account/tokens
VERCEL_TOKEN=

# Google Calendar — https://console.cloud.google.com/
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=primary

# Gmail (IMAP com App Password) — https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Web Push Notifications (VAPID) — gerar com: python3 -c "from pywebpush import webpush; from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key, v.private_key)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:seu@email.com

# === Filesystem ===
# Diretórios permitidos para leitura/escrita de arquivos (separados por vírgula)
AURA_ALLOWED_ROOTS=/Users/seu_usuario/Projetos
AURA_BASE_PROJECT_DIR=/Users/seu_usuario/Projetos
AURA_MAX_FILE_READ_SIZE=65536

# === Rate Limiting (requests por janela de tempo) ===
AURA_RATE_LIMIT_WINDOW_SECONDS=60
AURA_RATE_LIMIT_AUTH_REQUESTS=30
AURA_RATE_LIMIT_CHAT_REQUESTS=20
