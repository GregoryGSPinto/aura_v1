<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.gregory.aura.stack</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__AURA_REPO_ROOT__/scripts/run-aura-stack</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>WorkingDirectory</key>
  <string>__AURA_REPO_ROOT__</string>
  <key>StandardOutPath</key>
  <string>__AURA_LOG_DIR__/launchd.stack.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>__AURA_LOG_DIR__/launchd.stack.stderr.log</string>
</dict>
</plist>
