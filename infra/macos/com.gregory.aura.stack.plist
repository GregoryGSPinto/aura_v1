<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.gregory.aura.stack</string>

  <!-- boot.sh: Ollama → modelo → tunel → exec run-aura-stack (supervisor) -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__AURA_REPO_ROOT__/scripts/boot.sh</string>
  </array>

  <!-- Inicia ao login do usuário -->
  <key>RunAtLoad</key>
  <true/>

  <!-- KeepAlive=true: launchd reinicia o supervisor se ele cair.
       O boot.sh re-verifica Ollama e modelo antes de subir o stack. -->
  <key>KeepAlive</key>
  <true/>

  <!-- Não reinicia mais rápido que 60s para evitar loop de boot com erro -->
  <key>ThrottleInterval</key>
  <integer>60</integer>

  <key>WorkingDirectory</key>
  <string>__AURA_REPO_ROOT__</string>

  <key>StandardOutPath</key>
  <string>__AURA_LOG_DIR__/launchd.stack.stdout.log</string>

  <key>StandardErrorPath</key>
  <string>__AURA_LOG_DIR__/launchd.stack.stderr.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>HOME</key>
    <string>__USER_HOME__</string>
  </dict>

  <!-- AbandonProcessGroup: filhos continuam rodando se launchd parar o job -->
  <key>AbandonProcessGroup</key>
  <true/>
</dict>
</plist>
