#!/usr/bin/env bash
set -euo pipefail

# ============================================
# AURA START — Inicia backend + frontend + tunel
# O Ollama NAO inicia aqui — e controlado
# pelo botao de ignicao na interface.
# ============================================
#
# Uso:
#   ./scripts/aura-start            -> inicia tudo
#   ./scripts/aura-start stop       -> para tudo
#   ./scripts/aura-start status     -> mostra status
#   ./scripts/aura-start restart    -> reinicia tudo

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/aura-common.sh"

aura_init_environment
ensure_local_env_files
load_backend_env
load_frontend_env

BACKEND_PORT="${AURA_BACKEND_PORT:-8000}"
FRONTEND_PORT=3000
export AURA_FRONTEND_PORT="$FRONTEND_PORT"

BACKEND_PIDFILE="$(pidfile_path aura_backend)"
FRONTEND_PIDFILE="$(pidfile_path aura_frontend)"
TUNNEL_PIDFILE="$(pidfile_path aura_tunnel)"
BACKEND_LOGFILE="${AURA_LOG_DIR}/backend.log"
FRONTEND_LOGFILE="${AURA_LOG_DIR}/frontend.log"
TUNNEL_LOGFILE="${AURA_LOG_DIR}/tunnel.log"
TUNNEL_URL_FILE="${REPO_ROOT}/data/logs/tunnel_url.txt"

BACKEND_HEALTH_URL="http://localhost:${BACKEND_PORT}/api/v1/healthz"

# Mata qualquer processo zombie numa porta
kill_port_zombies() {
  local port="$1"
  local pids
  pids="$(lsof -ti:"$port" 2>/dev/null || true)"
  if [[ -n "$pids" ]]; then
    log_info "Limpando processos na porta ${port}..."
    echo "$pids" | xargs kill -9 2>/dev/null || true
    sleep 1
  fi
}

start_backend() {
  local pid
  pid="$(read_pidfile "$BACKEND_PIDFILE" || true)"
  if [[ -n "$pid" ]] && is_running_pid "$pid"; then
    log_info "Backend ja esta rodando (PID ${pid}, porta ${BACKEND_PORT})."
    return 0
  fi

  # Limpa zombies na porta
  kill_port_zombies "$BACKEND_PORT"

  log_info "Iniciando backend FastAPI..."
  nohup env AURA_BACKEND_RELOAD=0 AURA_BACKEND_HOST=0.0.0.0 AURA_BACKEND_PORT="$BACKEND_PORT" \
    "$SCRIPT_DIR/run-backend" >>"$BACKEND_LOGFILE" 2>&1 &
  write_pidfile "$BACKEND_PIDFILE" "$!"
  log_info "Backend iniciado (PID $!, porta ${BACKEND_PORT})."
}

start_frontend() {
  local pid
  pid="$(read_pidfile "$FRONTEND_PIDFILE" || true)"
  if [[ -n "$pid" ]] && is_running_pid "$pid"; then
    log_info "Frontend ja esta rodando (PID ${pid}, porta ${FRONTEND_PORT})."
    return 0
  fi

  # Limpa zombies na porta — garante porta 3000 livre
  kill_port_zombies "$FRONTEND_PORT"

  log_info "Iniciando frontend Next.js na porta ${FRONTEND_PORT}..."
  nohup env AURA_FRONTEND_HOST=localhost AURA_FRONTEND_PORT="$FRONTEND_PORT" \
    "$SCRIPT_DIR/run-frontend" >>"$FRONTEND_LOGFILE" 2>&1 &
  write_pidfile "$FRONTEND_PIDFILE" "$!"
  log_info "Frontend iniciado (PID $!, porta ${FRONTEND_PORT})."
}

start_tunnel() {
  if ! command -v cloudflared &>/dev/null; then
    log_warn "cloudflared nao instalado. Tunel desativado."
    return 0
  fi

  # Mata tunel anterior
  pkill -f "cloudflared tunnel" 2>/dev/null || true
  sleep 1

  mkdir -p "$(dirname "$TUNNEL_URL_FILE")"

  log_info "Iniciando tunel Cloudflare..."
  nohup cloudflared tunnel --url http://localhost:${BACKEND_PORT} \
    >"$TUNNEL_LOGFILE" 2>&1 &
  write_pidfile "$TUNNEL_PIDFILE" "$!"

  # Espera URL aparecer (nao bloqueante — max 40s em background)
  local url
  for _ in $(seq 1 20); do
    sleep 2
    url="$(grep -o 'https://[a-z0-9-]*\.trycloudflare\.com' "$TUNNEL_LOGFILE" 2>/dev/null | head -1 || true)"
    if [[ -n "$url" ]]; then
      echo "$url" > "$TUNNEL_URL_FILE"
      log_info "Tunel ativo: $url"
      return 0
    fi
  done
  log_warn "Tunel iniciou mas URL nao detectada ainda. Verifique: cat $TUNNEL_LOGFILE"
}

stop_all() {
  log_info "Parando Aura..."

  # Para tunel
  local pid
  pid="$(read_pidfile "$TUNNEL_PIDFILE" || true)"
  if [[ -n "$pid" ]] && is_running_pid "$pid"; then
    kill_pid_gracefully "$pid"
    log_info "  Tunel parado."
  fi
  remove_pidfile "$TUNNEL_PIDFILE"
  pkill -f "cloudflared tunnel" 2>/dev/null || true
  rm -f "$TUNNEL_URL_FILE"

  # Para backend
  pid="$(read_pidfile "$BACKEND_PIDFILE" || true)"
  if [[ -n "$pid" ]] && is_running_pid "$pid"; then
    kill_pid_gracefully "$pid"
    log_info "  Backend parado."
  fi
  remove_pidfile "$BACKEND_PIDFILE"

  # Para frontend
  pid="$(read_pidfile "$FRONTEND_PIDFILE" || true)"
  if [[ -n "$pid" ]] && is_running_pid "$pid"; then
    kill_pid_gracefully "$pid"
    log_info "  Frontend parado."
  fi
  remove_pidfile "$FRONTEND_PIDFILE"

  # Garante — mata por porta
  kill_port_zombies "$BACKEND_PORT"
  kill_port_zombies "$FRONTEND_PORT"

  # NAO mata Ollama — controlado pelo botao na interface

  log_info "Aura desligada."
}

show_status() {
  printf '=== AURA STATUS ===\n'

  local pid
  pid="$(read_pidfile "$BACKEND_PIDFILE" || true)"
  if [[ -n "$pid" ]] && is_running_pid "$pid"; then
    printf 'Backend:  rodando (PID %s, porta %s)\n' "$pid" "$BACKEND_PORT"
  elif port_is_listening "$BACKEND_PORT" && service_port_owned_by_aura "$BACKEND_PORT" aura_backend; then
    printf 'Backend:  rodando (porta %s)\n' "$BACKEND_PORT"
  else
    printf 'Backend:  parado\n'
  fi

  pid="$(read_pidfile "$FRONTEND_PIDFILE" || true)"
  if [[ -n "$pid" ]] && is_running_pid "$pid"; then
    printf 'Frontend: rodando (PID %s, porta %s)\n' "$pid" "$FRONTEND_PORT"
  elif port_is_listening "$FRONTEND_PORT" && service_port_owned_by_aura "$FRONTEND_PORT" aura_frontend; then
    printf 'Frontend: rodando (porta %s)\n' "$FRONTEND_PORT"
  else
    printf 'Frontend: parado\n'
  fi

  pid="$(read_pidfile "$TUNNEL_PIDFILE" || true)"
  if [[ -n "$pid" ]] && is_running_pid "$pid"; then
    local url="sem URL"
    if [[ -f "$TUNNEL_URL_FILE" ]]; then
      url="$(cat "$TUNNEL_URL_FILE")"
    fi
    printf 'Tunel:    rodando (PID %s, %s)\n' "$pid" "$url"
  else
    printf 'Tunel:    parado\n'
  fi

  if pgrep -f "ollama serve" >/dev/null 2>&1; then
    printf 'Ollama:   rodando (controlado pelo botao de ignicao)\n'
  else
    printf 'Ollama:   desligado (ligue pelo botao na interface)\n'
  fi
}

case "${1:-start}" in
  start)
    printf '============================================\n'
    printf '  AURA — Iniciando sistema\n'
    printf '============================================\n'
    start_backend
    sleep 2
    start_frontend
    sleep 2
    start_tunnel
    wait_for_http "backend" "$BACKEND_HEALTH_URL" 30 || true
    printf '\n'
    printf '  Local:  http://localhost:%s\n' "$FRONTEND_PORT"
    if [[ -f "$TUNNEL_URL_FILE" ]]; then
      printf '  Remoto: %s\n' "$(cat "$TUNNEL_URL_FILE")"
    fi
    printf '  Ollama: use o botao na interface pra ligar\n'
    ;;
  stop)
    stop_all
    ;;
  status)
    show_status
    ;;
  restart)
    stop_all
    sleep 2
    exec "$0" start
    ;;
  *)
    printf 'Uso: %s {start|stop|status|restart}\n' "$0"
    exit 1
    ;;
esac
