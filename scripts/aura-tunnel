#!/usr/bin/env bash
set -euo pipefail

# ============================================
# AURA TUNNEL — Expoe o backend na internet
# Usa ngrok com URL fixa (dominio reservado)
# ============================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
LOG_DIR="$REPO_ROOT/data/logs"
TUNNEL_PID_FILE="$LOG_DIR/tunnel.pid"
TUNNEL_URL_FILE="$LOG_DIR/tunnel_url.txt"
NGROK_URL="https://communistical-seedier-alisia.ngrok-free.dev"

mkdir -p "$LOG_DIR"

start_tunnel() {
    if [ -f "$TUNNEL_PID_FILE" ] && kill -0 "$(cat "$TUNNEL_PID_FILE")" 2>/dev/null; then
        printf '✅ Tunel ja esta rodando (PID %s)\n' "$(cat "$TUNNEL_PID_FILE")"
        printf '   URL: %s\n' "$NGROK_URL"
        return
    fi

    if ! command -v ngrok &>/dev/null; then
        printf '❌ ngrok nao instalado.\n'
        printf '   Instale: brew install ngrok\n'
        exit 1
    fi

    # Mata qualquer ngrok anterior
    pkill -f ngrok 2>/dev/null || true
    sleep 1

    printf '🌐 Iniciando tunel ngrok (URL fixa)...\n'

    nohup ngrok http 8000 --url communistical-seedier-alisia.ngrok-free.dev --log=stdout \
        > "$LOG_DIR/tunnel.log" 2>&1 &
    echo $! > "$TUNNEL_PID_FILE"
    echo "$NGROK_URL" > "$TUNNEL_URL_FILE"

    sleep 3

    if kill -0 "$(cat "$TUNNEL_PID_FILE")" 2>/dev/null; then
        printf '✅ Tunel ngrok ativo!\n'
        printf '   URL: %s\n' "$NGROK_URL"
    else
        printf '⚠️  ngrok pode ter falhado. Verifique: cat %s/tunnel.log\n' "$LOG_DIR"
    fi
}

stop_tunnel() {
    if [ -f "$TUNNEL_PID_FILE" ]; then
        PID="$(cat "$TUNNEL_PID_FILE")"
        if kill -0 "$PID" 2>/dev/null; then
            kill "$PID" 2>/dev/null || true
            printf '✅ Tunel parado (PID %s)\n' "$PID"
        fi
        rm -f "$TUNNEL_PID_FILE" "$TUNNEL_URL_FILE"
    else
        printf '⚫ Tunel nao estava rodando\n'
    fi

    # Mata processos restantes
    pkill -f ngrok 2>/dev/null || true
}

show_url() {
    if [ -f "$TUNNEL_URL_FILE" ]; then
        printf '🌐 %s\n' "$(cat "$TUNNEL_URL_FILE")"
    else
        printf '⚫ Tunel nao esta ativo\n'
    fi
}

case "${1:-start}" in
    start)   start_tunnel ;;
    stop)    stop_tunnel ;;
    url)     show_url ;;
    restart)
        stop_tunnel
        sleep 2
        start_tunnel
        ;;
    *)
        printf 'Uso: aura-tunnel {start|stop|url|restart}\n'
        ;;
esac
