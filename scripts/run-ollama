#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/aura-common.sh"

aura_init_environment
load_backend_env

require_command ollama

read -r OLLAMA_HOST OLLAMA_PORT < <(ollama_url_parts)
export OLLAMA_HOST="${AURA_OLLAMA_BIND:-${OLLAMA_HOST}:${OLLAMA_PORT}}"

if service_port_owned_by_aura "$OLLAMA_PORT" aura_ollama; then
  log_info "Ollama already listening on port $OLLAMA_PORT."
  exit 0
fi

if port_is_listening "$OLLAMA_PORT"; then
  log_error "Port $OLLAMA_PORT is already in use by a non-Ollama process."
  exit 1
fi

log_info "Starting Ollama on ${OLLAMA_HOST}."
exec ollama serve
